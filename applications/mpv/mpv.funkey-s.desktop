[Desktop Entry]
Name=MPV
Name[ch]=视频播放器
Comment=Native video player
Comment[ch]=原生视频播放器
Exec=run.sh %f
Icon=mpv
Terminal=false
Type=Application
StartupNotify=false
Categories=applications
SelectorDir=/mnt/Media
SelectorFilter=mp4,mkv,mpa,3gp,mpeg,rmvb,avi
MimeType=video/x-msvideo;video/mpeg;video/webm;video/mp4;video/x-matroska;video/quicktime;
