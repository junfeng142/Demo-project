+mv _opk/main.cpp _opk/Joueur.cpp _opk/Keyboard.cpp src/
+make MIYOO=1
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip zelda-olb -o _opk/zeldaolb
+unzip zelda_olb.zip
+mv zelda_olb/data _opk/
+mksquashfs _opk/* ../_opk/zeldaolb_funkey-s.opk -all-root -no-xattrs -noappend -no-exports
