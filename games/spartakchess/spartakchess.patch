diff -uprN a/build_opk.sh b/build_opk.sh
--- a/build_opk.sh	1970-01-01 08:00:00.000000000 +0800
+++ b/build_opk.sh	2026-03-08 18:41:06.514072207 +0800
@@ -0,0 +1,6 @@
+#!/bin/bash
+
+make -C build/bittboy
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip build/bittboy/Release/spartak-chess -o _opk/spartak-chess
+mv res _opk/
+mksquashfs _opk/* ../_opk/spartakchess_funkey-s.opk -all-root -no-xattrs -noappend -no-exports
