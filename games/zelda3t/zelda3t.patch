+++ b/build_opk.sh	2026-03-08 19:25:18.024040094 +0800
@@ -0,0 +1,7 @@
+#!/bin/bash
+mv _opk/main.cpp Joueur.cpp Keyboard.cpp src/
+make MIYOO=1
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip zelda3t -o _opk/zelda3t
