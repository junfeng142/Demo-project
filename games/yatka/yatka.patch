diff -uprN a/build_opk.sh b/build_opk.sh
--- a/build_opk.sh	1970-01-01 08:00:00.000000000 +0800
+++ b/build_opk.sh	2026-03-08 19:10:12.624051059 +0800
@@ -0,0 +1,6 @@
+#!/bin/bash
+
+make -f Makefile.bittboy
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip yatka -o _opk/yatka
+mv music sfx skins _opk/
+mksquashfs _opk/* ../_opk/yatka_funkey-s.opk -all-root -no-xattrs -noappend -no-exports
