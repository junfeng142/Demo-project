--- a/Makefile.bittboy	2026-02-16 13:08:31.896652598 +0800
+++ b/Makefile.bittboy	2026-02-16 13:21:45.626656717 +0800
@@ -1,6 +1,6 @@
 .PHONY: all clean zip
 
-BIN_BASE = /opt/miyoo/bin/
+BIN_BASE = /opt/mmiyoo/bin/
 PROJECT = yatka
 ZIPNAME = $(PROJECT).zip
 SRC = src/main.c src/data_persistence.c src/video.c src/sound.c \
@@ -8,9 +8,9 @@ SRC = src/main.c src/data_persistence.c
 	src/state_mainmenu.c src/skin.c
 OBJ = $(SRC:.c=.o)
 DEP = $(SRC:.c=.d)
-CFLAGS = -Iinc -D_BITTBOY -Ofast -march=armv5te -mtune=arm926ej-s
+CFLAGS = -Iinc -D_BITTBOY -Ofast -march=armv7-a -mtune=cortex-a7
 LDFLAGS = -s $(shell $(BIN_BASE)pkg-config --libs sdl SDL_image SDL_ttf SDL_mixer) -ljpeg -logg -lfreetype -lpng -lz -lbz2
-CC = arm-linux-gcc
+CC = /opt/mmiyoo/bin/arm-linux-gnueabihf-gcc
 
 all: $(PROJECT)
 
