diff -uprN a/build_opk.sh b/build_opk.sh
--- a/build_opk.sh	1970-01-01 08:00:00.000000000 +0800
+++ b/build_opk.sh	2026-03-08 19:02:20.954056772 +0800
@@ -0,0 +1,6 @@
+#!/bin/bash
+
+make
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip xrick.dge -o _opk/xrick
+mv data.zip _opk/
+mksquashfs _opk/* ../_opk/xrick_funkey-s.opk -all-root -no-xattrs -noappend -no-exports
