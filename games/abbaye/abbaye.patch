+++ b/build_opk.sh	2026-03-07 11:19:59.236318728 +0800
@@ -0,0 +1,7 @@
+#!/bin/bash
+
+make PLATFORM=bittboy
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip abbaye -o ./_opk/abbaye
