diff -uprN a/Makefile.funkey b/Makefile.funkey
--- a/Makefile.funkey	1970-01-01 08:00:00.000000000 +0800
+++ b/Makefile.funkey	2026-03-07 14:19:31.606332200 +0800
@@ -0,0 +1,33 @@
+# Project: FleshChasmerOne
+
+BIN_BASE = /opt/mmiyoo/
+CPP = /opt/mmiyoo/bin/arm-linux-gnueabihf-g++
+SYSROOT = $(shell $(CPP) --print-sysroot)
+SRC = $(wildcard ./*.c)
+OBJS = $(subst ./,build/,$(SRC))
+OBJ = $(OBJS:.c=.o)
+
+
+LIBS = -lSDL_mixer -lSDLmain -lSDL -lasound -lvorbisfile -lvorbis -logg
+INCS =  -I"$(SYSROOT)/usr/include/SDL" -I"./"
+BIN  = FleshChasmer
+FLAGS = $(INCS) -DPC -DPOCKETGO -fpermissive -fexpensive-optimizations -O3 -Wall -g
+RM = rm -f
+MKDIR = mkdir -p
+
+.PHONY: clean
+
+all: all-before FleshChasmer
+
+all-before:
+	$(MKDIR) "build"
+
+clean:
+	${RM} $(OBJ) $(BIN)
+
+$(BIN): $(OBJ)
+	$(CPP) -o $@ $^ $(LIBS)
+
+build/%.o : ./%.c
+	$(CPP) -c $< -o $@ $(FLAGS)
+
diff -uprN a/build_opk.sh b/build_opk.sh
--- a/build_opk.sh	1970-01-01 08:00:00.000000000 +0800
+++ b/build_opk.sh	2026-03-07 14:26:55.626332755 +0800
@@ -0,0 +1,7 @@
+#!/bin/bash
+
+make -f Makefile.funkey
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip FleshChasmer -o ./_opk/FleshChasmer
+mv data ./_opk/
+mksquashfs ./_opk/* ../_opk/FleshChasmer_funkey-s.opk -all-root -no-xattrs -noappend -no-exports
+
