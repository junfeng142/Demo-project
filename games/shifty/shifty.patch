+++ b/build_opk.sh	2026-03-08 10:50:00.221313275 +0800
@@ -0,0 +1,7 @@
+#!/bin/bash
+
+make PLATFORM=bittboy
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip output/arm-linux-gnueabihf/bin/shifty.elf -o _opk/shifty
