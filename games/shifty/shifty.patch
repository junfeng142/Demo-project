diff -uprN a/Makefile b/Makefile
--- a/Makefile	2026-02-17 16:21:09.999192325 +0800
+++ b/Makefile	2026-02-17 16:26:18.069190654 +0800
@@ -6,8 +6,8 @@ ifeq ($(PLATFORM), gcw0)
   LDFLAGS    := $(shell $(SYSROOT)/usr/bin/sdl-config --libs) -lm
 endif
 ifeq ($(PLATFORM), bittboy)
