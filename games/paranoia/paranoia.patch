diff -uprN a/Makefile.bittboy b/Makefile.bittboy
--- a/Makefile.bittboy	2026-02-18 11:06:38.292597437 +0800
+++ b/Makefile.bittboy	2026-02-18 11:10:47.932596082 +0800
@@ -1,9 +1,9 @@
 PROG = paranoia
 OBJS = renderer.o sdl-paranoia.o
 
-ARCH = arm-linux-
+ARCH = /opt/mmiyoo/bin/arm-linux-gnueabihf-
 CC = $(ARCH)gcc
-BINBASE = /opt/miyoo/bin/
+BINBASE = /opt/mmiyoo/bin/
 SYSROOT = $(shell $(CC) --print-sysroot)
 
 SDL_LIBS    := $(shell $(BINBASE)pkg-config --libs sdl)
diff -uprN a/build_opk.sh b/build_opk.sh
--- a/build_opk.sh	1970-01-01 08:00:00.000000000 +0800
+++ b/build_opk.sh	2026-03-08 10:39:17.721316761 +0800
@@ -0,0 +1,7 @@
+#!/bin/bash
+
+make -f Makefile.bittboy
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip paranoia -o _opk/paranoia
+mv opk/font.tga _opk/
+mksquashfs _opk/* ../_opk/paranoia_funkey-s.opk -all-root -no-xattrs -noappend -no-exports
+cd ..
