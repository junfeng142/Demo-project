diff -uprN a/build_opk.sh b/build_opk.sh
--- a/build_opk.sh	1970-01-01 08:00:00.000000000 +0800
+++ b/build_opk.sh	2026-03-08 10:55:14.931311567 +0800
@@ -0,0 +1,8 @@
+#!/bin/bash
+
+export PATH=$PATH:/opt/mmiyoo/bin
+make PLATFORM=bittboy
+/opt/mmiyoo/bin/arm-linux-gnueabihf-strip shisen.elf -o _opk/shisen
+mv data _opk/
+mksquashfs _opk/* ../_opk/shisen_funkey-s.opk -all-root -no-xattrs -noappend -no-exports
+
