diff -uprN a/Makefile b/Makefile
--- a/Makefile	2026-02-16 09:30:18.432199596 +0800
+++ b/Makefile	2026-02-16 09:31:56.712200106 +0800
@@ -19,8 +19,8 @@ ifeq ($(PLATFORM), a320)
 endif
 
 ifeq ($(PLATFORM), bittboy)
-	CC		:= arm-linux-gcc
-	STRIP		:= arm-linux-strip
+	CC		:= arm-linux-gnueabihf-gcc
+	STRIP		:= arm-linux-gnueabihf-strip
