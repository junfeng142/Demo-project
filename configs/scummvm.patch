diff -uprN a/build.sh b/build.sh
--- a/build.sh	1970-01-01 08:00:00.000000000 +0800
+++ b/build.sh	2025-12-27 16:34:13.543934278 +0800
@@ -0,0 +1,14 @@
+#!/bin/bash
+
+export PATH=$PATH:/opt/mmiyoo/bin
+export TARGETMACH=arm-linux
+export BUILDMACH=i686-pc-linux-gnu
+export CROSS=arm-linux-gnueabihf
+export CC=${CROSS}-gcc
+export LD=${CROSS}-ld
+export AS=${CROSS}-as
+export CXX=${CROSS}-g++
+
+./configure --host=miyoo --enable-release --enable-plugins --default-dynamic --enable-engine=testbed --enable-ext-neon --with-freetype2-prefix=/opt/mmiyoo/arm-buildroot-linux-gnueabihf/libc/usr/bin/
+
+make -j5 all sd-root sd-zip
