+void ReloadableScrollingText::renderTextToSurface()
+{
+    if (text_.empty()) return;
+    
+    Font* font = baseViewInfo.font ? baseViewInfo.font : fontInst_;
+    if (!font) return;
+    
+    std::string displayText;
+    
+    if (direction_ == "horizontal") {
+        displayText = text_[0];
+    } else {
+        for (size_t i = 0; i < text_.size(); ++i) {
+            if (i > 0) displayText += "\n";
+            displayText += text_[i];
+        }
+    }
+    
+    SDL_Surface* surface = font->renderText(displayText);
+    if (!surface) return;
+    
+    renderedText_ = surface;
+    renderedWidth_ = surface->w;
+    renderedHeight_ = surface->h;
+}
 
