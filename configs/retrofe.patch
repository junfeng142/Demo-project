-bool ReloadableScrollingText::mustRender(  )
-{
-    if ( Component::mustRender(  ) ) return true;
-
-    if (!text_.empty( ) && baseViewInfo.Alpha > 0.0f && needRender_)
-    {
+    
+    Font* font = baseViewInfo.font ? baseViewInfo.font : fontInst_;
+    if (!font) return;
+    
+    // 获取显示区域大小
+    float imageMaxWidth = 0;
+    float imageMaxHeight = 0;
+    
+    if (baseViewInfo.Width < baseViewInfo.MaxWidth && baseViewInfo.Width > 0) {
+        imageMaxWidth = baseViewInfo.Width;
+    } else {
+        imageMaxWidth = baseViewInfo.MaxWidth;
+    }
+    
+    if (baseViewInfo.Height < baseViewInfo.MaxHeight && baseViewInfo.Height > 0) {
+        imageMaxHeight = baseViewInfo.Height;
+    } else {
+        imageMaxHeight = baseViewInfo.MaxHeight;
+    }
+    
+    float xOrigin = baseViewInfo.XRelativeToOrigin();
+    float yOrigin = baseViewInfo.YRelativeToOrigin();
+    
+    if (direction_ == "horizontal") {
+        // 水平滚动：只显示可见部分
+        float textWidth = renderedWidth_ * scaleX_;
+        
+        // 计算源矩形
+        SDL_Rect srcRect;
+        srcRect.x = static_cast<int>(currentPosition_ / scaleX_);
+        if (srcRect.x < 0) srcRect.x = 0;
+        if (srcRect.x >= renderedWidth_) return;
+        
+        srcRect.y = 0;
+        srcRect.w = static_cast<int>(imageMaxWidth / scaleX_);
+        if (srcRect.x + srcRect.w > renderedWidth_) {
+            srcRect.w = renderedWidth_ - srcRect.x;
+        }
+        srcRect.h = renderedHeight_;
+        
+        // 计算目标矩形
+        SDL_Rect destRect;
+        destRect.w = static_cast<int>(srcRect.w * scaleX_);
+        destRect.h = static_cast<int>(srcRect.h * scaleY_);
+        destRect.x = static_cast<int>(xOrigin) - destRect.w / 2;
+        destRect.y = static_cast<int>(yOrigin) + destRect.h / 2;
+        
+        // 渲染
+        SDL::renderCopy(renderedText_, baseViewInfo.Alpha, &srcRect, &destRect, baseViewInfo);
+        
+        // 滚动位置更新
+        if (needScrolling_) {
+            float textEnd = textWidth - currentPosition_;
+            
+            // 重置滚动位置
+            if (scrollForward_ && waitStartTime_ <= 0 && textEnd <= imageMaxWidth) {
+                waitEndTime_ = endTime_;
+                scrollForward_ = false;
+                needRender_ = true;
+            } else if (!scrollForward_ && waitEndTime_ <= 0 && currentPosition_ <= -startPosition_ * scaleX_) {
+                waitStartTime_ = startTime_;
+                currentPosition_ = -startPosition_ * scaleX_;
+                scrollForward_ = true;
+                needRender_ = true;
+            }
+        }
+        
+    } else if (direction_ == "vertical") {
+        // 垂直滚动
+        float textHeight = renderedHeight_ * scaleY_;
+        
+        // 计算源矩形
+        SDL_Rect srcRect;
+        srcRect.x = 0;
+        srcRect.y = static_cast<int>(currentPosition_ / scaleY_);
+        if (srcRect.y < 0) srcRect.y = 0;
+        if (srcRect.y >= renderedHeight_) return;
+        
+        srcRect.w = renderedWidth_;
+        srcRect.h = static_cast<int>(imageMaxHeight / scaleY_);
+        if (srcRect.y + srcRect.h > renderedHeight_) {
+            srcRect.h = renderedHeight_ - srcRect.y;
+        }
+        
+        // 计算目标矩形
+        SDL_Rect destRect;
+        destRect.x = static_cast<int>(xOrigin);
+        destRect.y = static_cast<int>(yOrigin);
+        destRect.w = static_cast<int>(srcRect.w * scaleX_);
+        destRect.h = static_cast<int>(srcRect.h * scaleY_);
+        
+        // 渲染
+        SDL::renderCopy(renderedText_, baseViewInfo.Alpha, &srcRect, &destRect, baseViewInfo);
+        
+        // 重置滚动位置
+        if (needScrolling_ && currentPosition_ > textHeight - imageMaxHeight) {
+            waitStartTime_ = startTime_;
+            waitEndTime_ = endTime_;
+            currentPosition_ = -startPosition_ * scaleY_;
+        }
+    }
