 else
-STRIP                 = $(TOOLCHAIN_DIR)/usr/bin/arm-linux-strip
+STRIP                 = $(TOOLCHAIN_DIR)/bin/arm-funkey-linux-gnueabihf-strip
 endif
 
-SYSROOT              ?= $(shell $(CC) --print-sysroot)
+GCW0_SDL_CONFIG      ?= $(TOOLCHAIN_DIR)/arm-funkey-linux-gnueabihf/sysroot/usr/bin/sdl-config
+GCW0_FREETYPE_CONFIG ?= $(TOOLCHAIN_DIR)/arm-funkey-linux-gnueabihf/sysroot/usr/bin/freetype-config
 
-GCW0_SDL_CONFIG      ?= $(SYSROOT)/usr/bin/sdl-config
-GCW0_FREETYPE_CONFIG ?= $(SYSROOT)/usr/bin/freetype-config
-
-GCW0_INC_DIR         ?= $(SYSROOT)/usr/include
-GCW0_LIB_DIR         ?= $(SYSROOT)/usr/lib
+GCW0_INC_DIR         ?= $(TOOLCHAIN_DIR)/arm-funkey-linux-gnueabihf/sysroot/usr/include
+GCW0_LIB_DIR         ?= $(TOOLCHAIN_DIR)/arm-funkey-linux-gnueabihf/sysroot/usr/lib
 
 #########################
 #########################
@@ -72,7 +70,7 @@ HAVE_GLSL = 0
 HAVE_HID = 0
 HAVE_IBXM = 1
 HAVE_IMAGEVIEWER = 0
-HAVE_LANGEXTRA = 0
+HAVE_LANGEXTRA = 1
 HAVE_LIBRETRODB = 1
 HAVE_MENU = 1
 HAVE_MENU_COMMON = 1
@@ -120,7 +118,7 @@ TARGET = retroarch
 
