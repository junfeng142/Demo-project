@@ -69,26 +69,33 @@ bool axp209_init(void)
     if (ioctl(fd_axp209, I2C_SLAVE, AXP209_I2C_ADDR) < 0) {
         FK_DEBUG("Failed to acquire bus access and/or talk to slave, trying to force it\n");
         if (ioctl(fd_axp209, I2C_SLAVE_FORCE, AXP209_I2C_ADDR) < 0) {
-            FK_ERROR("Failed to acquire FORCED bus access and/or talk to slave.\n");
+            FK_DEBUG("Failed to acquire FORCED bus access and/or talk to slave.\n");
             return false;
         }
     }
 
     /* Set PEK Long press delay to 2.5s */
     if (i2c_smbus_write_byte_data(fd_axp209, AXP209_REG_PEK_PARAMS, 0x9F) < 0) {
-        FK_ERROR("Cannot set AXP209 PEK Long press delay to 2.5s\n");
+        FK_DEBUG("Cannot set AXP209 PEK Long press delay to 1.5s\n");
     }
 
     /* Set N_OE Shutdown delay to 3s*/
     if (i2c_smbus_write_byte_data(fd_axp209, AXP209_REG_32H, 0x47) < 0) {
-        FK_ERROR("Cannot set AXP209 N_OE Shutdown delay to 3s\n");
-    }
+        FK_DEBUG("Cannot set AXP209 N_OE Shutdown delay to 3s\n");
+    } 
 
     /* Enable only chosen interrupts (PEK short and long presses)*/
     if (i2c_smbus_write_byte_data(fd_axp209, AXP209_INTERRUPT_BANK_3_ENABLE,
         0x03) < 0) {
-        FK_ERROR("Cannot intiialize interrupt bank 3 for AXP209\n");
+        FK_DEBUG("Cannot intiialize interrupt bank 3 for AXP209\n");
+    } 
+    
+    /* Enable only chosen interrupts (N_OE status)*/
+    if (i2c_smbus_write_byte_data(fd_axp209, AXP209_INTERRUPT_BANK_4_ENABLE,
+        0x41) < 0) {
+        FK_DEBUG("Cannot intiialize interrupt bank 4 for AXP209\n");
     }
+    
     return true;
 }
 
@@ -119,3 +126,22 @@ int axp209_read_interrupt_bank_3(void)
     FK_DEBUG("READ AXP209_INTERRUPT_BANK_3_STATUS: 0x%02X\n", value);
     return value & 0xFF;
 }
+
+/* Read the AXP209 PMIC chip interrupt register bank 4 */
+int axp209_read_interrupt_bank_4(void)
+{
+  int value, result;
+
+    value = i2c_smbus_read_byte_data(fd_axp209, AXP209_INTERRUPT_BANK_4_STATUS);
+    if (value  < 0) {
+        return value;
+    }
+
+    /* Clear the interrupts */
+    result = i2c_smbus_write_byte_data(fd_axp209, AXP209_INTERRUPT_BANK_4_STATUS, 0xFF);
+    if (result < 0) {
+        return result;
+    }
+    FK_DEBUG("READ AXP209_INTERRUPT_BANK_4_STATUS: 0x%02X\n", value);
+    return value & 0xFF;
+}
